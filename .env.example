# 🏛️ DelhiConnect Environment Configuration Template
# Copy this file to './server/.env' and fill in your values.
# DO NOT commit the actual '.env' file containing active keys to git.

# 🌐 Server Port (defaults to 5001 if omitted)
PORT=5001

# 🌐 Authorized Client Origin for CORS
CLIENT_URL=http://localhost:5173

# 🗄️ Database Connection string (MongoDB Local or Atlas)
MONGODB_URI=mongodb://localhost:27017/delhiconnect

# 🔑 JWT Signing Secret (used to sign user session tokens)
JWT_SECRET=your_jwt_signing_secret_here

# 🤖 Gemini AI API Key (for smart routing)
# Leave as 'mock' to run the rule-based local classifier without a real API key.
GEMINI_API_KEY=mock

# 💬 Twilio Integration details (optional, for WhatsApp SMS)
# Leave empty to print notifications to the server console log instead.
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
